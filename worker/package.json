{
  "name": "fund-tracker-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute fund-tracker-db --local --file=./src/db/schema.sql",
    "db:init:remote": "wrangler d1 execute fund-tracker-db --remote --file=./src/db/schema.sql",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.8.0"
  }
}
